        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o\",\n  \"instructions\": \"{{$json.system_prompt}}\",\n  \"input\": \"{{$json.prompt}}\",\n  \"text\": {\n    \"format\": {\n      \"type\": \"json_schema\",\n      \"name\": \"ticket_analysis\",\n      \"strict\": true,\n      \"schema\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"category\": { \"type\": \"string\" },\n          \"priority\": {\n            \"type\": \"string\",\n            \"enum\": [\"Bassa\", \"Media\", \"Alta\", \"Critica\"]\n          },\n          \"possible_cause\": { \"type\": \"string\" },\n          \"first_steps\": {\n            \"type\": \"array\",\n            \"items\": { \"type\": \"string\" }\n          },\n          \"escalation\": { \"type\": \"boolean\" }\n        },\n        \"required\": [\n          \"category\",\n          \"priority\",\n          \"possible_cause\",\n          \"first_steps\",\n          \"escalation\"\n        ],\n        \"additionalProperties\": false\n      }\n    }\n  }\n}",
        "options": {}
      },
